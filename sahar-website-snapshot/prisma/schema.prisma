generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Brand {
  id      Int      @id @default(autoincrement())
  name    String

  devices Device[]
}

model Device {
  id       Int      @id @default(autoincrement())
  name     String

  brandId  Int
  brand    Brand @relation(fields: [brandId], references: [id])

  repairs  RepairCase[]
}

model RepairCase {
  id          Int      @id @default(autoincrement())
  title       String

  slug        String   @unique

  problem     String
  solution    String

  repairTime  String?   // ✅ your required field

  image       String?
  beforeImage String?
  afterImage  String?
  videoUrl    String?

  deviceId Int?
  device   Device? @relation(fields: [deviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}